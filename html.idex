<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Carregando Conteúdo VIP...</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            background-color: #ffffff;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            margin: 0;
        }
        .loader {
            border: 4px solid #f3f3f3;
            border-top: 4px solid #25d366;
            border-radius: 50%;
            width: 40px;
            height: 40px;
            animation: spin 1s linear infinite;
        }
        @keyframes spin {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }
    </style>

    <script>
        // Configurações
        const numero = "5561982319771";
        const mensagem = encodeURIComponent("Vim garantir o meu conteúdo vip");
        const urlWhatsapp = `https://api.whatsapp.com/send?phone=${numero}&text=${mensagem}`;

        // Função de redirecionamento
        function redirecionar() {
            // O delay de 500ms ajuda a evitar que o crawler do FB identifique o redirect imediato
            setTimeout(function() {
                window.location.href = urlWhatsapp;
            }, 500);
        }

        window.onload = redirecionar;
    </script>
</head>
<body>

    <div class="loader"></div>
    <p style="margin-left: 15px; color: #555;">Conectando ao servidor seguro...</p>

</body>
</html>

